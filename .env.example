# ========== 数据库 ==========
# Nuxt runtimeConfig 非 public 变量必须带 NUXT_ 前缀
NUXT_DATABASE_URL=postgresql://user:password@localhost:5432/gaokao_countdown

# ========== reCAPTCHA ==========
# 在 https://www.google.com/recaptcha/admin 申请密钥
NUXT_PUBLIC_RECAPTCHA_SITE_KEY=your_site_key_here
NUXT_RECAPTCHA_SECRET=your_secret_key_here

# ========== 管理员 ==========
# 后台登录密码 (请修改为强密码)
NUXT_ADMIN_PASSWORD=admin123

# ========== JWT ==========
# 用于签发管理员 token（请用随机字符串替换）
NUXT_JWT_SECRET=change-me-to-a-random-string-at-least-32-chars

# ========== 站点 ==========
NUXT_PUBLIC_SITE_NAME=高考倒计时
